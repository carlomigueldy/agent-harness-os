# ── Secrets & environment ─────────────────────────────────────────────
# Never commit secrets. Copy .env.example -> .env locally; keep .env ignored.
.env
.env.*
!.env.example
*.env
*.local
secrets.*
*.pem
*.key
*.p12
*.pfx
id_rsa
id_ed25519
*.keystore
.npmrc
.netrc
service-account*.json
gha-creds-*.json

# ── Dependencies ──────────────────────────────────────────────────────
node_modules/
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/releases
!.yarn/plugins
!.yarn/versions
vendor/
.venv/
venv/
__pycache__/
*.py[cod]
.mypy_cache/
.ruff_cache/
.pytest_cache/
# Rust / JVM build output
target/

# ── Build & cache output ──────────────────────────────────────────────
dist/
build/
out/
.next/
.nuxt/
.svelte-kit/
.turbo/
.cache/
coverage/
*.tsbuildinfo

# ── Logs & runtime ────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*
# root-level runtime log dir only
/logs/
!.agents/logs/         # harness logs are tracked state — never ignore them

# ── Editor & OS ───────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/extensions.json
*.swp

# ── Harness artifacts ─────────────────────────────────────────────────
# Keep the artifacts directory tracked (README + .gitkeep), but ignore
# large captured media by default. Commit small evidence intentionally.
.agents/artifacts/**
!.agents/artifacts/README.md
!.agents/artifacts/.gitkeep

# ── Git worktrees ────────────────────────────────────────────────────────
# PREFERRED convention: sibling directories OUTSIDE the repo tree, e.g.
#   ../<repo>-worktrees/<branch-name>
# These live outside the tree, so no .gitignore entry is needed for them.
#
# IN-REPO worktrees: when tooling or Claude Code creates a worktree inside
# the repo, the directory must be ignored. Covered base dirs (repo-root-
# anchored so only top-level dirs are matched):
/worktrees/
/.worktrees/
# Claude Code's own in-repo worktree directory is also ignored:
# (see the Claude Code project config section below for .claude/worktrees/)
#
# ARBITRARY in-repo worktree names (e.g. a dir named /claire/ or /sandbox/):
# add the path to .git/info/exclude — local, per-clone, never committed.
# `scripts/worktree.sh create --in-repo` does this automatically; for a
# worktree created by hand, run `bash scripts/worktree.sh sync-exclude` to
# exclude every in-repo worktree. No tracked-file change is needed.

# ── Local provisioning config ─────────────────────────────────────────
# harness.config.example is tracked (documentation); the local working copy
# that adopters create by copying it is never committed.
harness.config

# ── Claude Code project config ────────────────────────────────────────
# Track the invokable harness surfaces (commands/, skills/) and their
# in-repo context docs (.claude/README.md, .claude/skills/AGENTS.md).
# Ignore only local/personal Claude Code state.
.claude/settings.local.json
.claude/worktrees/
